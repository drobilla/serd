Checks: >
  -*-magic-numbers,
  -bugprone-inc-dec-in-conditions,
  -cert-err33-c,
  -hicpp-signed-bitwise,
  -llvm-header-guard,
InheritParentConfig: true
CheckOptions:
  - key:   readability-function-cognitive-complexity.IgnoreMacros
    value: 'true'
  - key:   readability-function-cognitive-complexity.Threshold
    value: '101'
