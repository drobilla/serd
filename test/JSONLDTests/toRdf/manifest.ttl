	mf:name "@import is invalid in 1.0." ;
	mf:result "invalid context entry" ;
	jld:option [
		jld:processingMode "json-ld-1.0"^^xsd:string ;
		jld:specVersion "json-ld-1.1"^^xsd:string
	] .

<#tso02>
