Checks: >
  *,
  -*-macro-to-enum,
  -altera-*,
  -llvmlibc-*,
CheckOptions:
  - key:   readability-function-cognitive-complexity.Threshold
    value: '1'
  - key:   readability-identifier-length.IgnoredParameterNames
    value: '^(id|s|p|o|g|r|t|v)$'
WarningsAsErrors: '*'
HeaderFilterRegex: '.*'
FormatStyle: file
