@prefix eg: <http://example.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

eg:Alpha
	a rdfs:Datatype ;
	rdfs:label "Alpha" ;
	owl:onDatatype eg:Beta .

eg:Beta
	a rdfs:Datatype ;
	rdfs:label "Beta" ;
	owl:onDatatype eg:Omega .

eg:Omega
	a rdfs:Datatype ;
	rdfs:label "Omega" ;
	owl:onDatatype eg:Alpha .
