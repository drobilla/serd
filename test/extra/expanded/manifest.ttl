@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdft: <http://www.w3.org/ns/rdftest#> .

<>
	a mf:Manifest ;
	rdfs:comment "Serd expanded test suite" ;
	mf:entries (
		<#expanded>
		<#expanded-uris>
		<#repeated-statements>
	) .

<#expanded>
	a rdft:TestTurtleEval ;
	mf:action <qualified.ttl> ;
	mf:name "expanded" ;
	mf:result <expanded.ttl> .

<#expanded-uris>
	a rdft:TestTurtleEval ;
	mf:action <abbreviated-uris.ttl> ;
	mf:name "expanded-uris" ;
	mf:result <expanded-uris.ttl> .

<#repeated-statements>
	a rdft:TestTurtleEval ;
	mf:action <repeated-statements-in.ttl> ;
	mf:name "repeated-statements" ;
	mf:result <repeated-statements-out.ttl> .
