Checks: >
  -*-magic-numbers,
  -bugprone-easily-swappable-parameters,
  -bugprone-switch-missing-default-case,
  -cert-err33-c,
  -clang-diagnostic-unused-function,
  -hicpp-multiway-paths-covered,
  -hicpp-signed-bitwise,
  -llvm-header-guard,
  -misc-no-recursion,
InheritParentConfig: true
