PROJECT_NAME           = Serd
PROJECT_BRIEF          = "A lightweight library for RDF storage and serialisation"

QUIET                  = YES
WARN_AS_ERROR          = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = NO

CASE_SENSE_NAMES       = YES
EXTRACT_ALL            = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_UNDOC_MEMBERS     = YES
INHERIT_DOCS           = NO
INLINE_INHERITED_MEMB  = NO
REFERENCES_LINK_SOURCE = NO

AUTOLINK_SUPPORT       = NO
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
JAVADOC_AUTOBRIEF      = YES
SHOW_FILES             = NO
XML_PROGRAMLISTING     = NO

MACRO_EXPANSION        = YES
PREDEFINED             = SERD_ALLOCATED \
                         SERD_API \
                         SERD_CONST_FUNC= \
                         SERD_DEPRECATED_BY(x)= \
                         SERD_DISABLE_DEPRECATED \
                         SERD_NONNULL= \
                         SERD_NULLABLE= \
                         SERD_PURE_FUNC=

RECURSIVE              = YES
STRIP_FROM_PATH        = @SERD_SRCDIR@
INPUT                  = @SERD_SRCDIR@/include \
                         @SERD_SRCDIR@/bindings/cpp/include

OUTPUT_DIRECTORY       = @DOX_OUTPUT@
